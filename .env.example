# ==========================================================================
# SANAÉRA — Environment Variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# ==========================================================================

# --- Database (Neon or Supabase Postgres) ---------------------------------
# DATABASE_URL: pooled connection string (used at runtime, e.g. Neon's pooler
# or Supabase's "Transaction" pooler on port 6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sanaera?sslmode=require"
# DIRECT_URL: unpooled connection, required by Prisma Migrate.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/sanaera?sslmode=require"

# --- Auth.js ---------------------------------------------------------------
# Generate with: npx auth secret   (or `openssl rand -base64 32`)
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Cloudinary (product/avatar/banner image uploads) ----------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Public unsigned upload preset, if you want client-side direct uploads too:
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# --- Razorpay ---------------------------------------------------------------
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# --- Email (Nodemailer via SMTP, e.g. Postmark / SES / Resend SMTP) --------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="SANAÉRA <hello@sanaera.com>"

# --- App -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Rate limiting (optional — Upstash Redis, used by middleware) ----------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
